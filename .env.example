OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high

# Optional workspace root for Portfolio Brand Brain and Direct Install.
# Defaults to ~/Documents/Codex/Workspace on macOS.
WORKSPACE_ROOT=

# Optional live design-reference provider bridge.
# Leave empty to use the built-in Auto Design Scout.
# Set DESIGN_SCOUT_PROVIDER=designmd-cli to use DESIGNmd search through npx.
# Set DESIGN_SCOUT_PROVIDER=lazyweb-http or refero-http when a local/API bridge is available.
DESIGN_SCOUT_PROVIDER=builtin
DESIGNMD_API_KEY=
DESIGNMD_API_URL=https://designmd.ai/api/v1
DESIGN_SCOUT_HTTP_URL=
DESIGN_SCOUT_HTTP_TOKEN=
